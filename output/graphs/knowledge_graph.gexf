          <attvalue for="3" value="employer" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="The historian and wartime codebreaker Asa Briggs has said, &quot;You needed exceptional talent, you needed genius at Bletchley and Turing's was that genius.&quot;&#10;From September 1938, Turing worked part-time with the Government Code and Cypher School (GC&amp;CS), the British codebreaking organisation." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
        </attvalues>
      </edge>
      <edge source="the Polish Cipher Bureau" target="Warsaw" id="128">
