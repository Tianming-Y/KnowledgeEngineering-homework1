        <attvalues>
          <attvalue for="3" value="country" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="Turing travelled to the United States in November 1942 and worked with US Navy cryptanalysts on the naval Enigma and bombe construction in Washington." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
        </attvalues>
