          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="In 1941, Turing proposed marriage to Hut 8 colleague Joan Clarke , a fellow mathematician and cryptanalyst, but their engagement was short-lived." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
        </attvalues>
      </edge>
