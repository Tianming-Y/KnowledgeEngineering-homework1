          <attvalue for="3" value="birth_place" />
          <attvalue for="4" value="0.8" />
          <attvalue for="5" value="Turing was born in Maida Vale , London, while his father, Julius Mathison Turing, was on leave from his position with the Indian Civil Service (ICS) of the British Raj government at Chatrapur , then in the Madras Presidency and presently in Odisha state, in India ." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="silver" />
        </attvalues>
      </edge>
