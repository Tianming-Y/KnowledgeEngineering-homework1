          <attvalue for="3" value="located in the administrative territorial entity" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="Soon after the July 1939 meeting near Warsaw at which the Polish Cipher Bureau gave the British and French details of the wiring of Enigma machine's rotors and their method of decrypting Enigma machine 's messages, Turing and Knox developed a broader solution." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
        </attvalues>
