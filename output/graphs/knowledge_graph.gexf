      <edge source="Alan Turing" target="Enigma" id="17">
        <attvalues>
          <attvalue for="3" value="known_for" />
          <attvalue for="4" value="0.8" />
          <attvalue for="5" value="Turing devised techniques for speeding the breaking of German ciphers, including improvements to the pre-war Polish bomba method, an electromechanical machine that could find settings for the Enigma machine." />
