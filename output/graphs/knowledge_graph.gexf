          <attvalue for="3" value="employer" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="The cryptographers at Bletchley Park did not know of the Prime Minister's response, but as Milner-Barry recalled, &quot;All that we did notice was that almost from that day the rough ways began miraculously to be made smooth.&quot; More than two hundred bombes were in operation by the end of the war." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
        </attvalues>
      </edge>
