      <edge source="Alan Turing" target="the United Kingdom" id="22">
        <attvalues>
          <attvalue for="3" value="country" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="The Alan Turing law is now an informal term for the law in the United Kingdom, contained in the Policing and Crime Act 2017 , which serves as an amnesty law to retroactively pardon men who were cautioned or convicted under historical legislation that outlawed homosexual acts." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
        </attvalues>
      </edge>
      <edge source="Alan Turing" target="Cambridge" id="23">
        <attvalues>
          <attvalue for="3" value="educated_at" />
          <attvalue for="4" value="0.8" />
          <attvalue for="5" value="After graduating from Sherborne, Turing applied for several Cambridge colleges scholarships, including Trinity and King's , eventually earning an £80 per annum scholarship (equivalent to about £4,300 as of 2023) to study at the latter." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="silver" />
        </attvalues>
      </edge>
      <edge source="Alan Turing" target="Church" id="24">
        <attvalues>
          <attvalue for="3" value="doctoral_advisor" />
          <attvalue for="4" value="0.8" />
          <attvalue for="5" value="Although Turing's proof was published shortly after Church's equivalent proof using his lambda calculus , Turing's approach is considerably more accessible and intuitive than Church's." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="silver" />
        </attvalues>
      </edge>
      <edge source="Alan Turing" target="&quot; The Chemical Basis of Morphogenesis &quot;" id="25">
        <attvalues>
          <attvalue for="3" value="known_for" />
          <attvalue for="4" value="0.8" />
          <attvalue for="5" value="When Turing was 39 years old in 1951, he turned to mathematical biology , finally publishing his masterpiece &quot; The Chemical Basis of Morphogenesis &quot; in January 1952." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="silver" />
        </attvalues>
      </edge>
      <edge source="Alan Turing" target="Andrew Hodges" id="26">
        <attvalues>
          <attvalue for="3" value="influenced by" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="As Andrew Hodges , biographer of Turing, later wrote, &quot;This letter had an electric effect.&quot; Churchill wrote a memo to General Ismay , which read: &quot;ACTION THIS DAY." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
        </attvalues>
      </edge>
