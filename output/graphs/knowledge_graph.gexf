          <attvalue for="3" value="worked_at" />
          <attvalue for="4" value="0.8" />
          <attvalue for="5" value="In 1948, Turing joined Max Newman's Computing Machine Laboratory at the University of Manchester, where he contributed to the development of early Manchester computers and became interested in mathematical biology." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="silver" />
        </attvalues>
      </edge>
