          <attvalue for="3" value="legislated by" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="To implement the pardon, the British Government announced on 20 October 2016 that it would support an amendment to the Policing and Crime Bill that would provide a posthumous pardon, and provide a process whereby those still living could apply to have these offences disregarded." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
        </attvalues>
      </edge>
