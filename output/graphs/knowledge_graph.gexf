      <edge source="Alan Turing" target="Universal Machine'" id="36">
        <attvalues>
          <attvalue for="3" value="subclass of" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="It also included a notion of a 'Universal Machine' (now known as a universal Turing machine ), with the idea that such a machine could perform the tasks of any other computation machine (as indeed could Church's lambda calculus)." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
