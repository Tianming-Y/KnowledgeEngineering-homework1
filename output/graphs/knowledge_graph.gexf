          <attvalue for="3" value="notable work" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="In this paper, Turing reformulated Kurt Gödel 's 1931 results on the limits of proof and computation, replacing Gödel's universal arithmetic-based formal language with the formal and simple hypothetical devices that became known as Turing machines ." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
        </attvalues>
      </edge>
