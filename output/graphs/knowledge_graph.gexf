          <attvalue for="3" value="chairperson" />
          <attvalue for="4" value="1.0" />
          <attvalue for="5" value="During his absence, Hugh Alexander had officially assumed the position of head of Hut 8, although Alexander had been de facto head for some time (Turing having little interest in the day-to-day running of the section)." />
          <attvalue for="6" value="" />
          <attvalue for="7" value="rebel" />
